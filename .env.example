# ─────────────────────────────────────────────────────────────────
# COMO CRIAR O .env.local
#
# 1. Copie este arquivo:  cp .env.example .env.local
# 2. Preencha SUPABASE_SERVICE_ROLE_KEY (veja instruções abaixo)
# 3. Configure as mesmas variáveis no painel da Vercel antes do deploy
# ─────────────────────────────────────────────────────────────────

# ── URL do site ──────────────────────────────────────────────────
# Em produção: URL gerada pela Vercel (ex: https://presente-dia-dos-pais.vercel.app)
# Em desenvolvimento: http://localhost:3000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Supabase ─────────────────────────────────────────────────────
# Projeto: presente-dia-dos-pais (sa-east-1 / MBL Technology)
# Dashboard: https://supabase.com/dashboard/project/njdbqkmrgabnamdbewtv

# URL pública do projeto (pode comitar — não é segredo)
NEXT_PUBLIC_SUPABASE_URL=https://njdbqkmrgabnamdbewtv.supabase.co

# Service Role Key — NUNCA exponha no client nem comite no git
# Onde pegar: https://supabase.com/dashboard/project/njdbqkmrgabnamdbewtv/settings/api
#             → seção "Project API keys" → "service_role" → "Reveal"
SUPABASE_SERVICE_ROLE_KEY=

# ── Cakto ────────────────────────────────────────────────────────
# Link do checkout do produto (já configurado)
NEXT_PUBLIC_CAKTO_CHECKOUT_URL=https://pay.cakto.com.br/cbwju7a_944001

# Secret do webhook — configure em: Cakto dashboard → produto → Webhooks
# URL do webhook: https://<seu-domínio-vercel>/api/webhook/cakto
# Deixe vazio para pular a validação (não recomendado em produção)
CAKTO_WEBHOOK_SECRET=

# ── Config do produto ─────────────────────────────────────────────
# Preço exibido na landing (apenas visual — o valor real é configurado no Cakto)
NEXT_PUBLIC_PRECO=29
